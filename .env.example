POSTGRES_DB=tts_admin
POSTGRES_USER=tts_admin
POSTGRES_PASSWORD=tts_admin_change_me
DATABASE_URL=postgresql+psycopg://tts_admin:tts_admin_change_me@postgres:5432/tts_admin
REDIS_URL=redis://redis:6379/0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=TTS Admin Stack
API_PREFIX=/api/v1
DATA_DIR=/data
FRONTEND_ORIGIN=http://localhost:8080

# Legacy fallback
TTS_BACKEND=qwen

# Explicit backend split
PREVIEW_BACKEND=qwen
LIVE_BACKEND=mock

# Qwen preview
QWEN_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
QWEN_DEVICE=cuda:0
QWEN_DTYPE=bfloat16
QWEN_ATTN_IMPLEMENTATION=sdpa
QWEN_COMPILE=false
QWEN_MAX_CONCURRENT=2
QWEN_PREVIEW_STYLE=Четко, спокойно, как технический диктор.

# Optional legacy cloud realtime Qwen
QWEN_REALTIME_WS_URL=
QWEN_REALTIME_API_KEY=
QWEN_REALTIME_MODEL=qwen3-tts-flash-realtime
QWEN_REALTIME_MODE=commit
QWEN_REALTIME_SAMPLE_RATE=24000
QWEN_REALTIME_FORMAT=pcm

AUDIO_SAMPLE_RATE=24000
TRAINING_POLL_SECONDS=5

LIVE_BUFFER_IDLE_MS=220