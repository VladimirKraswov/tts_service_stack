POSTGRES_DB=tts_admin
POSTGRES_USER=tts_admin
POSTGRES_PASSWORD=tts_admin_change_me
DATABASE_URL=postgresql+psycopg://tts_admin:tts_admin_change_me@postgres:5432/tts_admin
REDIS_URL=redis://redis:6379/0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TITLE=TTS Admin Stack
API_PREFIX=/api/v1
DATA_DIR=/data

# Live backend:
# qwen_realtime = realtime live over DashScope WebSocket
# qwen = local/offline Qwen for preview and legacy live
# mock = test/dev fallback
TTS_BACKEND=qwen_realtime

# Local/offline Qwen settings (used by Preview mode)
QWEN_MODEL_NAME=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
QWEN_DEVICE=cuda:0
QWEN_DTYPE=bfloat16
QWEN_ATTN_IMPLEMENTATION=sdpa
QWEN_COMPILE=false
QWEN_MAX_CONCURRENT=2
QWEN_PREVIEW_STYLE=Четко, спокойно, как технический диктор.

# Realtime Qwen settings (used by Live mode)
# Singapore region example:
QWEN_REALTIME_WS_URL=wss://dashscope-intl.aliyuncs.com/api-ws/v1/realtime
QWEN_REALTIME_API_KEY=replace_with_real_api_key
# Use instruct model if you want live style control through instructions
QWEN_REALTIME_MODEL=qwen3-tts-instruct-flash-realtime
QWEN_REALTIME_MODE=commit
QWEN_REALTIME_SAMPLE_RATE=24000
QWEN_REALTIME_FORMAT=pcm

TRAINING_POLL_SECONDS=5
FRONTEND_ORIGIN=http://localhost:8080

LIVE_BUFFER_IDLE_MS=120
LIVE_BUFFER_SOFT_FLUSH_CHARS=24
LIVE_BUFFER_TARGET_CHARS=36
LIVE_BUFFER_MAX_CHARS=56
LIVE_PCM_CHUNK_MS=40
LIVE_DICTIONARY_CACHE_TTL_SECONDS=10