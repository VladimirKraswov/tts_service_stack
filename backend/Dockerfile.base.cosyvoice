FROM nvidia/cuda:12.8.1-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:${PATH} \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH} \
    PIP_NO_CACHE_DIR=1 \
    PYTHONUNBUFFERED=1 \
    COSYVOICE_ROOT=/opt/CosyVoice \
    PYTHONPATH=/opt/CosyVoice:/opt/CosyVoice/third_party/Matcha-TTS

WORKDIR /opt/cosyvoice-base

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-venv \
    python3-pip \
    python3-dev \
    build-essential \
    git \
    ca-certificates \
    ffmpeg \
    sox \
    libsox-dev \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python && \
    python -m pip install --upgrade "pip<25.1" "setuptools<82" wheel packaging

RUN git clone --recursive https://github.com/FunAudioLLM/CosyVoice.git ${COSYVOICE_ROOT} && \
    cd ${COSYVOICE_ROOT} && \
    git submodule update --init --recursive

RUN python -m pip install --no-build-isolation openai-whisper==20231117

RUN grep -Ev '^(openai-whisper==20231117|torch([<=> ].*)?|torchaudio([<=> ].*)?|torchvision([<=> ].*)?)$' \
      ${COSYVOICE_ROOT}/requirements.txt > /tmp/cosyvoice-requirements.txt && \
    python -m pip install -r /tmp/cosyvoice-requirements.txt

# Final override: force Blackwell-compatible torch at the very end
RUN python -m pip uninstall -y torch torchvision torchaudio || true && \
    python -m pip install \
      torch==2.7.1 \
      torchvision==0.22.1 \
      torchaudio==2.7.1 \
      --index-url https://download.pytorch.org/whl/cu128

RUN python - <<'PY'
import sys
print("python:", sys.version)

import torch
print("torch:", torch.__version__)
print("cuda:", torch.version.cuda)
print("cuda available:", torch.cuda.is_available())
if torch.cuda.is_available():
    print("device:", torch.cuda.get_device_name(0))
    print("capability:", torch.cuda.get_device_capability(0))

import whisper
print("whisper:", whisper.__file__)
PY